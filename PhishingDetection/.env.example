# PhishGuard — Environment Variables
# Copy this file to .env and replace with YOUR real keys.
# WARNING: Never commit .env to git — it's in .gitignore for a reason!

# ----------------------------------------------------------
# LLM: Groq API (FREE - No GPU needed, runs Llama 3 in cloud)
# Get a free key at: https://console.groq.com (no credit card)
# ----------------------------------------------------------
GROQ_API_KEY="your_groq_api_key_here"

# ----------------------------------------------------------
# OpenAI (Only needed if you want GPT-4 instead of Groq/vLLM)
# ----------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ----------------------------------------------------------
# Threat Intel APIs (Optional — for future integrations)
# ----------------------------------------------------------
# VirusTotal
# VIRUSTOTAL_API_KEY=your_virustotal_key_here

# AbuseIPDB
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# PhishTank
PHISHTANK_API_KEY=your_phishtank_key_here
